#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require 'dotenv/load'
require 'logger'

require 'r2'

# Logger padrão da CLI (não usar logger global do R2)
logger = Logger.new($stdout)
logger.level = Logger::ERROR

# Formato simplificado para saída de CLI
logger.formatter = proc do |_severity, _datetime, _progname, msg|
  "[R2] #{msg}\n"
end

client = R2::Client.new(
  access_key_id: ENV.fetch('R2_ACCESS_KEY_ID'),
  secret_access_key: ENV.fetch('R2_SECRET_ACCESS_KEY'),
  endpoint: ENV.fetch('R2_ENDPOINT'),
  region: ENV.fetch('R2_REGION', 'auto'),
)

client.logger = logger

# Injeta client na CLI (dependency injection simples)
R2::CLI.client = client

begin
  R2::CLI.start(ARGV)
rescue StandardError => e
  logger.error(e.full_message)

  warn("[R2] #{e.message}")
  exit(1)
end
