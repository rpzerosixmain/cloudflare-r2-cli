#!/usr/bin/env ruby
# frozen_string_literal: true

require 'dotenv/load'
require 'logger'

require 'r2'

# Progress logger; verbosity is controlled by the --verbose flag inside the CLI.
logger = Logger.new($stdout)
logger.level = Logger::ERROR
logger.formatter = proc { |_severity, _datetime, _progname, msg| "[R2] #{msg}\n" }

begin
  # Storage is built lazily so commands like `r2 help` work without credentials.
  storage_factory = -> { R2::Storage.new(**R2::Configuration.from_env.to_h) }

  R2::CLI.start(ARGV, storage_factory: storage_factory, logger: logger)
rescue R2::Error => e
  # Expected, user-facing failures: show a concise message on stderr.
  warn("[R2] #{e.message}")
  exit(1)
rescue StandardError => e
  # Unexpected failures: concise by default, full trace only when debugging.
  warn("[R2] #{e.message}")
  warn(e.full_message) if ENV['R2_DEBUG'] == '1'
  exit(1)
end
