#!/usr/bin/env ruby
# frozen_string_literal: true

require 'bundler/setup'
require 'dotenv/load'
require 'logger'

require 'r2'

# Default CLI logger (do not use R2 global logger)
logger = Logger.new($stdout)
logger.level = Logger::ERROR

# Simplified format for CLI output
logger.formatter = proc do |_severity, _datetime, _progname, msg|
  "[R2] #{msg}\n"
end

begin
  storage = R2::Storage.new(
    access_key_id: ENV.fetch('R2_ACCESS_KEY_ID'),
    secret_access_key: ENV.fetch('R2_SECRET_ACCESS_KEY'),
    endpoint: ENV.fetch('R2_ENDPOINT'),
    region: ENV.fetch('R2_REGION', 'auto'),
  )
rescue KeyError => e
  warn("[R2] missing required environment variable: #{e.key}")
  exit(1)
end

storage.logger = logger

# Injects storage into CLI (simple dependency injection)
R2::CLI.storage = storage

begin
  R2::CLI.start(ARGV)
rescue R2::Error => e
  logger.error(e.full_message)

  warn("[R2] #{e.message}")
  exit(1)
rescue StandardError => e
  logger.error(e.full_message)

  warn("[R2] unexpected error: #{e.message}")
  exit(1)
end
